# ============================================================
# MongoDB
# ============================================================
# Exemple: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/portfolio
MONGODB_URI=

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_URL=http://localhost:3000
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=

# Compte admin unique (pas de collection User)
ADMIN_EMAIL=
# Généré via: npm run hash -- "votre-mot-de-passe"
ADMIN_PASSWORD_HASH=

# ============================================================
# Cloudinary (unsigned upload)
# ============================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
